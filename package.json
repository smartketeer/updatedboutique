{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "contrast:check": "node scripts/contrast-check.mjs",
        "dev": "vite",
        "dev:full": "concurrently -n PHP,VITE -c magenta,cyan \"php artisan serve --host 127.0.0.1 --port 8000\" \"npm run dev\"",
        "test:unit": "vitest run",
        "test:visual": "playwright test",
        "test": "npm run test:unit && npm run contrast:check"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@vitejs/plugin-react": "^6.0.1",
        "axios": "^1.15.2",
        "concurrently": "^9.0.1",
        "jsdom": "^26.1.0",
        "laravel-vite-plugin": "^3.0.0",
        "rollup": "npm:@rollup/wasm-node@4.60.2",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.10",
        "@heroicons/react": "^2.2.0",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.2",
        "tailwind-merge": "^3.5.0",
        "zustand": "^5.0.12"
    }
}
